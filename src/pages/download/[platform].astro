---
// [platform].astro
import { platforms } from '../../data/platforms';
import DownloaderForm from '../../components/DownloaderForm.astro';
import "../../styles/global.css";

export function getStaticPaths() {
  return platforms.map((platform) => ({
    params: { platform: platform.id },
    props: { platform },
  }));
}

const { platform } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{platform.shortName} Downloader - KiraDownloader</title>
	</head>
	<body class="bg-[#F8F9FA] text-[#333333] font-sans min-h-screen flex flex-col">
		<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
				<a href="/" class="flex items-center gap-2 hover:opacity-80 transition cursor-pointer">
					<div class="w-8 h-8 rounded bg-red-500 text-white flex items-center justify-center font-bold">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
						</svg>
					</div>
					<span class="font-extrabold text-xl tracking-tight text-gray-900">Kirara</span>
				</a>
				<nav class="hidden md:flex gap-6 text-sm font-semibold text-gray-600">
					<a href="#" class="hover:text-red-500 transition">Pricing</a>
				</nav>
			</div>
		</header>

		<main class="grow w-full py-12 md:py-20 px-4 sm:px-6 lg:px-8">
			
			<div class="text-center mb-10">
				<div class={`inline-flex justify-center items-center w-16 h-16 rounded-2xl mb-4 shadow-md ${platform.colorBg} ${platform.colorText}`}>
                    <Fragment set:html={platform.svg} />
                </div>
				<h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">{platform.name}</h1>
				<p class="text-lg text-gray-500 max-w-2xl mx-auto font-medium">{platform.description}</p>
			</div>

			<DownloaderForm platform={platform} />
			
			<div class="max-w-7xl mx-auto mt-20 pt-10 border-t border-gray-200">
				<h2 class="text-2xl font-bold text-gray-900 text-center mb-10">Latest Downloads on {platform.shortName}</h2>
				<div id="recent-downloads" class="flex overflow-x-auto pb-8 gap-6 snap-x hide-scrollbar"></div>
				<p id="recent-downloads-status" class="text-center text-sm text-gray-500">Loading recent downloads...</p>
			</div>

			<div class="max-w-4xl mx-auto mt-10 pt-10 border-t border-gray-200">
				<h2 class="text-2xl font-bold text-gray-900 text-center mb-10">How to download from {platform.shortName}?</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="text-center">
						<div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">1</div>
						<h4 class="font-bold text-gray-900 mb-2">Copy link</h4>
						<p class="text-gray-500 text-sm">Open {platform.shortName}, find the video or media and copy its URL via the Share button.</p>
					</div>
					<div class="text-center">
						<div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">2</div>
						<h4 class="font-bold text-gray-900 mb-2">Paste link</h4>
						<p class="text-gray-500 text-sm">Paste the copied URL into the input field above and hit the the Download button.</p>
					</div>
					<div class="text-center">
						<div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">3</div>
						<h4 class="font-bold text-gray-900 mb-2">Download</h4>
						<p class="text-gray-500 text-sm">Choose your preferred format (MP4 or MP3) and the download will start instantly.</p>
					</div>
				</div>
			</div>
		</main>

		<footer class="border-t border-gray-200 bg-white mt-auto">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col md:flex-row items-center justify-between">
				<p class="text-gray-500 text-sm mb-4 md:mb-0">
					© 2026 KiraDownloader. Fast, Secure, and Free.
				</p>
				<div class="flex space-x-6 text-sm">
					<a href="#" class="text-gray-500 hover:text-gray-900 transition font-medium">Terms</a>
					<a href="#" class="text-gray-500 hover:text-gray-900 transition font-medium">Privacy</a>
					<a href="#" class="text-gray-500 hover:text-gray-900 transition font-medium">Contact</a>
				</div>
			</div>
		</footer>

		<script is:inline define:vars={{ platformId: platform.id }}>
			const recentDownloadsContainer = document.getElementById("recent-downloads");
			const recentDownloadsStatus = document.getElementById("recent-downloads-status");
			const normalizedPlatform = platformId === "twitter" ? "x" : platformId;

			function escapeHtml(value) {
				return String(value)
					.replace(/&/g, "&amp;")
					.replace(/</g, "&lt;")
					.replace(/>/g, "&gt;")
					.replace(/\"/g, "&quot;")
					.replace(/'/g, "&#39;");
			}

			function formatDate(value) {
				if (!value) return "Unknown date";
				const date = new Date(value);
				if (Number.isNaN(date.getTime())) return "Unknown date";
				return date.toLocaleString();
			}

			function renderDownloads(downloads) {
				if (!recentDownloadsContainer || !recentDownloadsStatus) return;

				if (!downloads.length) {
					recentDownloadsContainer.innerHTML = "";
					recentDownloadsStatus.textContent = "No downloads yet for this platform.";
					return;
				}

				recentDownloadsStatus.textContent = "";
				recentDownloadsContainer.innerHTML = downloads
					.map((item) => {
						const title = escapeHtml(item.title || item.name || "Untitled download");
						const count = Number(item.download_count) || 1;
						const mediaKind = item.file_type === "image" ? "Image" : "Video";
						const formatLabel = escapeHtml((item.file_format || (item.file_type === "image" ? "jpg" : "mp4")).toUpperCase());
						const downloadedAt = escapeHtml(formatDate(item.downloaded_at));
						const sourceUrl = escapeHtml(item.url || "#");

						const previewContent = item.file_type === "video" 
							? `<video src="${sourceUrl}" preload="metadata" class="absolute inset-0 w-full h-full object-cover" muted loop playsinline onmouseover="this.play()" onmouseout="this.pause()" title="Video preview">
							<source src="${sourceUrl}" type="${item.file_type === "image" ? `image/${item.file_format || "jpeg"}` : `video/${item.file_format || "mp4"}`}">
								</video>`
							: `<div class="text-center px-4 z-10 relative">
									<p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">${escapeHtml(mediaKind)}</p>
									<p class="text-sm font-medium text-gray-700 mt-1">${formatLabel}</p>
								</div>`;

						return `
							<div class="min-w-[250px] bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden snap-center group hover:shadow-md transition flex flex-col relative">
								<a href="${sourceUrl}" target="_blank" rel="noopener noreferrer" class="relative aspect-[9/16] bg-gradient-to-br from-gray-50 to-gray-200 flex items-center justify-center overflow-hidden block">
									${previewContent}
								</a>
								<div class="p-4 flex flex-col grow">
									<h4 class="font-bold text-gray-900 mb-1 truncate" title="${title}">${title}</h4>
									<div class="flex items-center justify-between mt-auto">
										<div>
											<p class="text-xs text-gray-500">${count} total downloads</p>
											<p class="text-xs text-gray-400 mt-1">${downloadedAt}</p>
										</div>
										<button type="button" data-url="${sourceUrl}" class="quick-download-btn text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2.5 rounded-full transition" title="Download">
											<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
											</svg>
										</button>
									</div>
								</div>
							</div>
						`;
					})
					.join("");
			}

			async function loadRecentDownloads() {
				if (!recentDownloadsStatus) return;
				recentDownloadsStatus.textContent = "Loading recent downloads...";

				try {
					const response = await fetch(`http://localhost:8000/downloads?platform=${encodeURIComponent(normalizedPlatform)}&limit=10`);
					if (!response.ok) {
						throw new Error(`Failed with status ${response.status}`);
					}

					const payload = await response.json();
					const downloads = Array.isArray(payload.downloads) ? payload.downloads : [];
					renderDownloads(downloads);
				} catch (error) {
					if (recentDownloadsContainer) {
						recentDownloadsContainer.innerHTML = "";
					}
					recentDownloadsStatus.textContent = "Could not load recent downloads right now.";
					console.error("Failed to load recent downloads:", error);
				}
			}

			window.addEventListener("kirara:download-success", (event) => {
				const detail = event.detail || {};
				const eventPlatform = detail.platform === "twitter" ? "x" : detail.platform;
				if (eventPlatform !== normalizedPlatform) {
					return;
				}
				void loadRecentDownloads();
			});

			if (recentDownloadsContainer) {
				recentDownloadsContainer.addEventListener("click", (e) => {
					const btn = e.target.closest('.quick-download-btn');
					if (!btn) return;
					e.preventDefault();
					const url = btn.getAttribute('data-url');
					if (url) {
						const urlInput = document.getElementById('url-input');
						const form = document.getElementById('download-form');
						if (urlInput && form) {
							urlInput.value = url;
							form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
							window.scrollTo({ top: 0, behavior: 'smooth' });
						}
					}
				});
			}

			void loadRecentDownloads();
		</script>
	</body>
</html>