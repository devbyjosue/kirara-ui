---
// [platform].astro
import { platforms } from '../../data/platforms';
import DownloaderForm from '../../components/DownloaderForm.astro';
import "../../styles/global.css";

export function getStaticPaths() {
  return platforms.map((platform) => ({
    params: { platform: platform.id },
    props: { platform },
  }));
}

const { platform } = Astro.props;

// Mock data for popular downloads
const popularDownloads = [
  { title: "Trending Dance Challenge", downloads: "1.2M", thumbnail: "https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?auto=format&fit=crop&w=300&q=80", duration: "0:15" },
  { title: "Funny Cat Compilation", downloads: "850K", thumbnail: "https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&w=300&q=80", duration: "3:42" },
  { title: "Quick Recipe Tutorial", downloads: "2.4M", thumbnail: "https://images.unsplash.com/photo-1466637574441-749b8f19452f?auto=format&fit=crop&w=300&q=80", duration: "1:00" },
  { title: "Travel Vlog Highlight", downloads: "500K", thumbnail: "https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=300&q=80", duration: "5:20" },
  { title: "Life Hack #42", downloads: "3.1M", thumbnail: "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=300&q=80", duration: "0:45" }
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{platform.shortName} Downloader - KiraDownloader</title>
	</head>
	<body class="bg-[#F8F9FA] text-[#333333] font-sans min-h-screen flex flex-col">
		<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
				<a href="/" class="flex items-center gap-2 hover:opacity-80 transition cursor-pointer">
					<div class="w-8 h-8 rounded bg-red-500 text-white flex items-center justify-center font-bold">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
						</svg>
					</div>
					<span class="font-extrabold text-xl tracking-tight text-gray-900">Kirara</span>
				</a>
				<nav class="hidden md:flex gap-6 text-sm font-semibold text-gray-600">
					<a href="#" class="hover:text-red-500 transition">Pricing</a>
				</nav>
			</div>
		</header>

		<main class="grow w-full py-12 md:py-20 px-4 sm:px-6 lg:px-8">
			
			<div class="text-center mb-10">
				<div class={`inline-flex justify-center items-center w-16 h-16 rounded-2xl mb-4 shadow-md ${platform.colorBg} ${platform.colorText}`}>
                    <Fragment set:html={platform.svg} />
                </div>
				<h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">{platform.name}</h1>
				<p class="text-lg text-gray-500 max-w-2xl mx-auto font-medium">{platform.description}</p>
			</div>

			<DownloaderForm platform={platform} />
			
			<div class="max-w-7xl mx-auto mt-20 pt-10 border-t border-gray-200">
				<h2 class="text-2xl font-bold text-gray-900 text-center mb-10">Trending on {platform.shortName}</h2>
				<div class="flex overflow-x-auto pb-8 gap-6 snap-x hide-scrollbar">
					{popularDownloads.map((item) => (
						<div class="min-w-[250px] bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden snap-center group cursor-pointer hover:shadow-md transition">
							<div class="relative aspect-[9/16] bg-gray-200">
								<img src={item.thumbnail} alt={item.title} class="w-full h-full object-cover" />
								<div class="absolute bottom-2 right-2 bg-black/70 text-white text-xs px-2 py-1 rounded-md font-medium">{item.duration}</div>
								<div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition flex items-center justify-center">
									<div class="w-12 h-12 bg-white/90 rounded-full flex items-center justify-center pl-1 shadow-lg opacity-0 group-hover:opacity-100 transition-opacity transform scale-75 group-hover:scale-100">
										<svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
									</div>
								</div>
							</div>
							<div class="p-4">
								<h4 class="font-bold text-gray-900 mb-1 truncate">{item.title}</h4>
								<p class="text-xs text-gray-500">{item.downloads} downloads</p>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="max-w-4xl mx-auto mt-10 pt-10 border-t border-gray-200">
				<h2 class="text-2xl font-bold text-gray-900 text-center mb-10">How to download from {platform.shortName}?</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="text-center">
						<div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">1</div>
						<h4 class="font-bold text-gray-900 mb-2">Copy link</h4>
						<p class="text-gray-500 text-sm">Open {platform.shortName}, find the video or media and copy its URL via the Share button.</p>
					</div>
					<div class="text-center">
						<div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">2</div>
						<h4 class="font-bold text-gray-900 mb-2">Paste link</h4>
						<p class="text-gray-500 text-sm">Paste the copied URL into the input field above and hit the the Download button.</p>
					</div>
					<div class="text-center">
						<div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">3</div>
						<h4 class="font-bold text-gray-900 mb-2">Download</h4>
						<p class="text-gray-500 text-sm">Choose your preferred format (MP4 or MP3) and the download will start instantly.</p>
					</div>
				</div>
			</div>
		</main>

		<footer class="border-t border-gray-200 bg-white mt-auto">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col md:flex-row items-center justify-between">
				<p class="text-gray-500 text-sm mb-4 md:mb-0">
					© 2026 KiraDownloader. Fast, Secure, and Free.
				</p>
				<div class="flex space-x-6 text-sm">
					<a href="#" class="text-gray-500 hover:text-gray-900 transition font-medium">Terms</a>
					<a href="#" class="text-gray-500 hover:text-gray-900 transition font-medium">Privacy</a>
					<a href="#" class="text-gray-500 hover:text-gray-900 transition font-medium">Contact</a>
				</div>
			</div>
		</footer>

		
	</body>
</html>